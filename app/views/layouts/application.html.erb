<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <meta name="google-site-verification" content="CJWZsOMIp9lEb42BXtPpsxgTM8R7tDqu0kQ3jBincXw" />
    <title><%= content_for(:title) || "별라채팅 - 실시간 채팅 서비스" %></title>
    <meta name="description" content="<%= content_for(:meta_description) || "별라채팅에서 실시간으로 대화하세요. 안전하고 빠른 프라이빗 메시징 서비스입니다." %>">
    <meta name="keywords" content="별라채팅, 실시간 채팅, 메시징, 프라이빗 채팅, 1:1 대화">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= content_for(:title) || "별라채팅 - 실시간 채팅 서비스" %>">
    <meta property="og:description" content="<%= content_for(:meta_description) || "별라채팅에서 실시간으로 대화하세요. 안전하고 빠른 프라이빗 메시징 서비스입니다." %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= request.base_url %>/icon.png">
    <meta property="og:site_name" content="별라채팅">
    <meta property="og:locale" content="ko_KR">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:title) || "별라채팅 - 실시간 채팅 서비스" %>">
    <meta name="twitter:description" content="<%= content_for(:meta_description) || "별라채팅에서 실시간으로 대화하세요. 안전하고 빠른 프라이빗 메시징 서비스입니다." %>">
    <meta name="twitter:image" content="<%= request.base_url %>/icon.png">

    <!-- Canonical URL -->
    <link rel="canonical" href="<%= request.original_url.split('?').first %>">

    <!-- 반응형 디자인을 위한 뷰포트 설정 -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="별라채팅">
    <meta name="mobile-web-app-capable" content="yes">

    <!-- Rails 보안 토큰 및 CSP 설정 -->
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <!-- 파비콘 설정 -->
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- 스타일시트 로드 -->
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <!-- JavaScript 모듈 로드 (ActionCable 포함) -->
    <%= javascript_importmap_tags %>

    <!-- Google Fonts: Noto Sans KR (한글 폰트) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
  </head>

  <body>
    <!-- Flash 메시지 표시 (로그인 성공/실패 등) -->
    <% if notice.present? %>
      <div class="flash-notice"><%= notice %></div>
    <% end %>

    <% if alert.present? %>
      <div class="flash-alert"><%= alert %></div>
    <% end %>

    <script>
      document.addEventListener("turbo:load", function() {
        document.querySelectorAll(".flash-notice, .flash-alert").forEach(function(el) {
          setTimeout(function() {
            el.style.transition = "opacity 0.4s ease-out";
            el.style.opacity = "0";
            setTimeout(function() { el.remove(); }, 400);
          }, 1000);
        });
      });
    </script>
    
    <!-- 메인 컨텐츠 -->
    <%= yield %>
  </body>
</html>
