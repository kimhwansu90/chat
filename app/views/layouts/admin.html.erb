<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "LeadHub" %></title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
  </head>

  <body class="admin-body">
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
          <h2>LeadHub</h2>
          <span class="sidebar-user-role"><%= current_user_record&.nickname %></span>
        </div>
        <nav class="admin-nav">
          <a href="<%= admin_root_path %>" class="admin-nav-item <%= 'active' if controller_name == 'dashboard' %>">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            대시보드
          </a>
          <a href="<%= admin_leads_path %>" class="admin-nav-item <%= 'active' if controller_name == 'leads' || controller_name == 'lead_activities' %>">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            리드 관리
          </a>
          <a href="<%= admin_forms_path %>" class="admin-nav-item <%= 'active' if controller_name == 'forms' %>">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14,2 14,8 20,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            문의 폼
          </a>
          <% if current_user_record&.manager_or_above? %>
            <a href="<%= admin_nad_accounts_path %>" class="admin-nav-item <%= 'active' if controller_name.start_with?('nad') %>">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><line x1="8" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              광고 관리
            </a>
            <a href="<%= admin_reports_path %>" class="admin-nav-item <%= 'active' if controller_name == 'reports' %>">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><line x1="18" y1="20" x2="18" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="20" x2="12" y2="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="6" y1="20" x2="6" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              리포트
            </a>
          <% end %>
          <% if current_user_record&.admin? %>
            <a href="<%= admin_users_path %>" class="admin-nav-item <%= 'active' if controller_name == 'users' %>">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              팀 관리
            </a>
          <% end %>
        </nav>
        <div class="admin-sidebar-footer">
          <%= button_to "로그아웃", logout_path, method: :delete, class: "admin-logout-btn" %>
        </div>
      </aside>

      <main class="admin-main">
        <% if notice.present? %>
          <div class="flash-notice"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="flash-alert"><%= alert %></div>
        <% end %>

        <script>
          document.addEventListener("turbo:load", function() {
            document.querySelectorAll(".flash-notice, .flash-alert").forEach(function(el) {
              setTimeout(function() {
                el.style.transition = "opacity 0.4s ease-out";
                el.style.opacity = "0";
                setTimeout(function() { el.remove(); }, 400);
              }, 1500);
            });
          });
        </script>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
