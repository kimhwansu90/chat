<% content_for(:title, "로그인 - HS Solution") %>
<div class="login-container">
  <div class="login-box">
    <div class="login-header">
      <div class="app-logo">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <rect width="48" height="48" rx="12" fill="#4e598c"/>
          <path d="M14 34V14h6l4 12 4-12h6v20M14 24h14" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1 class="app-title">HS Solution</h1>
      <p class="app-subtitle">리드 관리 시스템</p>
    </div>

    <%= form_with url: login_path, method: :post, class: "login-form" do |f| %>
      <div class="form-group">
        <%= f.text_field :username,
            placeholder: "아이디",
            class: "form-input",
            required: true,
            autofocus: true,
            autocomplete: "username" %>
      </div>

      <div class="form-group">
        <%= f.password_field :password,
            placeholder: "비밀번호",
            class: "form-input",
            required: true,
            autocomplete: "current-password" %>
      </div>

      <div class="form-group">
        <%= f.submit "로그인", class: "btn-primary btn-full" %>
      </div>
    <% end %>

    <div class="login-footer">
      <p class="info-text">인가된 사용자만 접속할 수 있습니다</p>
    </div>
  </div>
</div>
