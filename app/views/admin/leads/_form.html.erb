<%= form_with model: [:admin, lead], local: true do |f| %>
  <% if lead.errors.any? %>
    <div class="form-errors">
      <% lead.errors.full_messages.each do |msg| %>
        <p class="error-text"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <label class="form-label">이름 *</label>
    <%= f.text_field :name, class: "form-input", required: true, placeholder: "고객 이름" %>
  </div>

  <div class="form-group">
    <label class="form-label">전화번호</label>
    <%= f.text_field :phone, class: "form-input", placeholder: "010-1234-5678" %>
  </div>

  <div class="form-group">
    <label class="form-label">이메일</label>
    <%= f.email_field :email, class: "form-input", placeholder: "example@email.com" %>
  </div>

  <div class="form-group">
    <label class="form-label">상태</label>
    <%= f.select :status, Lead::STATUSES.map { |s| [Lead::STATUS_LABELS[s], s] }, {}, class: "form-select" %>
  </div>

  <div class="form-group">
    <label class="form-label">담당자</label>
    <%= f.select :assigned_to_id,
        @sales_reps.map { |u| [u.nickname, u.id] },
        { include_blank: "미배정" },
        class: "form-select" %>
  </div>

  <div class="form-group">
    <label class="form-label">유입 소스</label>
    <%= f.text_field :utm_source, class: "form-input", placeholder: "naver, meta, google 등" %>
  </div>

  <div class="form-group">
    <label class="form-label">캠페인</label>
    <%= f.text_field :utm_campaign, class: "form-input", placeholder: "캠페인명" %>
  </div>

  <div class="form-actions">
    <%= f.submit lead.persisted? ? "수정" : "등록", class: "btn-primary" %>
    <%= link_to "취소", admin_leads_path, class: "btn-secondary" %>
  </div>
<% end %>
