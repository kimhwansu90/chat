<%= link_to admin_lead_path(lead), class: "lead-card", id: "lead_#{lead.id}",
    draggable: true, data: { lead_id: lead.id, action: "dragstart->pipeline#dragStart dragend->pipeline#dragEnd" } do %>
  <div class="lead-card-name"><%= lead.name %></div>
  <% if lead.phone.present? %>
    <div class="lead-card-info"><%= lead.phone %></div>
  <% end %>
  <div class="lead-card-meta">
    <% if lead.utm_source.present? %>
      <span class="lead-card-source"><%= lead.utm_source %></span>
    <% else %>
      <span class="lead-card-source">직접</span>
    <% end %>
    <% if lead.assigned_to %>
      <span class="lead-card-assignee">
        <span class="assignee-dot"></span>
        <%= lead.assigned_to.nickname %>
      </span>
    <% else %>
      <span style="color: var(--warning); font-size: 11px;">미배정</span>
    <% end %>
  </div>
<% end %>
