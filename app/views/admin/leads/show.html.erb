<% content_for(:title, "#{@lead.name} - HS Solution") %>
<div class="page-header">
  <div>
    <h1 class="page-title"><%= @lead.name %></h1>
    <p class="page-subtitle">
      <span class="badge badge-<%= @lead.status %>"><%= @lead.status_label %></span>
      <% if @lead.form %>
        &middot; <%= @lead.form.name %>
      <% end %>
      <% if @lead.contract_value.to_i > 0 %>
        &middot; <strong style="color: var(--success);">계약 <%= number_with_delimiter(@lead.contract_value) %>원</strong>
      <% end %>
    </p>
  </div>
  <div class="btn-group">
    <%= link_to "수정", edit_admin_lead_path(@lead), class: "btn-secondary btn-sm" %>
    <%= link_to "목록", admin_leads_path, class: "btn-secondary btn-sm" %>
  </div>
</div>

<div class="lead-detail-layout">
  <div class="lead-info-section">
    <div class="card">
      <div class="card-header">기본 정보</div>
      <div class="card-body">
        <div class="info-row">
          <span class="info-label">이름</span>
          <span class="info-value"><%= @lead.name %></span>
        </div>
        <div class="info-row">
          <span class="info-label">전화번호</span>
          <span class="info-value"><%= @lead.phone || "-" %></span>
        </div>
        <div class="info-row">
          <span class="info-label">이메일</span>
          <span class="info-value"><%= @lead.email || "-" %></span>
        </div>
        <div class="info-row">
          <span class="info-label">등록일</span>
          <span class="info-value"><%= @lead.created_at.strftime("%Y-%m-%d %H:%M") %></span>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">유입 정보</div>
      <div class="card-body">
        <div class="info-row">
          <span class="info-label">소스</span>
          <span class="info-value"><%= @lead.utm_source || "-" %></span>
        </div>
        <div class="info-row">
          <span class="info-label">매체</span>
          <span class="info-value"><%= @lead.utm_medium || "-" %></span>
        </div>
        <div class="info-row">
          <span class="info-label">캠페인</span>
          <span class="info-value"><%= @lead.utm_campaign || "-" %></span>
        </div>
        <div class="info-row">
          <span class="info-label">랜딩 페이지</span>
          <span class="info-value" style="font-size: 12px; word-break: break-all;"><%= @lead.landing_page_url || "-" %></span>
        </div>
      </div>
    </div>

    <%# 계약 정보 카드 %>
    <div class="card" style="border-left: 4px solid var(--success);">
      <div class="card-header" style="color: var(--success);">💰 계약 정보</div>
      <div class="card-body">
        <% if @lead.contract_value.to_i > 0 %>
          <div class="info-row">
            <span class="info-label">계약금액</span>
            <span class="info-value" style="font-size: 18px; font-weight: 700; color: var(--success);">
              <%= number_with_delimiter(@lead.contract_value) %>원
            </span>
          </div>
          <% if @lead.contracted_at %>
            <div class="info-row">
              <span class="info-label">계약일</span>
              <span class="info-value"><%= @lead.contracted_at.strftime("%Y-%m-%d") %></span>
            </div>
          <% end %>
          <%= button_to "계약 삭제", clear_contract_admin_lead_path(@lead), method: :delete,
              class: "btn-danger btn-sm",
              style: "margin-bottom: 8px;",
              data: { turbo_confirm: "계약 정보를 삭제하시겠습니까?" } %>
        <% else %>
          <p class="info-text" style="margin-bottom: 12px;">계약 완료 시 금액을 입력하세요.</p>
        <% end %>

        <%= form_with url: update_contract_admin_lead_path(@lead), method: :patch, local: true,
            style: "display: flex; gap: 8px; margin-top: 12px;" do |f| %>
          <div style="flex: 1; position: relative;">
            <input type="number" name="contract_value"
                   value="<%= @lead.contract_value.to_i > 0 ? @lead.contract_value : "" %>"
                   class="form-input" placeholder="계약금액 (원)" min="0" step="10000"
                   style="padding-right: 32px;">
            <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 13px;">원</span>
          </div>
          <button type="submit" class="btn-success">저장</button>
        <% end %>
      </div>
    </div>

    <div class="card">
      <div class="card-header">상태 변경</div>
      <div class="card-body">
        <div class="btn-group">
          <% Lead::STATUSES.each do |status| %>
            <% if status != @lead.status %>
              <%= button_to Lead::STATUS_LABELS[status],
                  update_status_admin_lead_path(@lead, status: status),
                  method: :patch,
                  class: "btn-secondary btn-sm" %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">담당자 배정</div>
      <div class="card-body">
        <p style="margin-bottom: 12px; font-size: 14px;">
          현재: <strong><%= @lead.assigned_to&.nickname || "미배정" %></strong>
        </p>
        <div class="btn-group">
          <% @sales_reps.each do |rep| %>
            <% next if rep.id == @lead.assigned_to_id %>
            <%= button_to rep.nickname,
                assign_admin_lead_path(@lead, sales_rep_id: rep.id),
                method: :post,
                class: "btn-secondary btn-sm" %>
          <% end %>
        </div>
      </div>
    </div>

    <% if @lead.custom_fields.present? && @lead.custom_fields.any? %>
      <div class="card">
        <div class="card-header">추가 정보</div>
        <div class="card-body">
          <% @lead.custom_fields.each do |key, value| %>
            <% next if %w[name phone email].include?(key) %>
            <div class="info-row">
              <span class="info-label"><%= key %></span>
              <span class="info-value"><%= value %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="lead-info-section">
    <div class="card">
      <div class="card-header">메모 추가</div>
      <div class="card-body">
        <%= form_with model: LeadActivity.new, url: admin_lead_activities_path(@lead), method: :post do |f| %>
          <%= f.hidden_field :activity_type, value: "note" %>
          <div class="form-group">
            <textarea name="lead_activity[content]" class="form-textarea" placeholder="메모를 입력하세요..." rows="3" required></textarea>
          </div>
          <div class="form-actions">
            <%= f.submit "메모 추가", class: "btn-primary btn-sm" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card">
      <div class="card-header">활동 기록</div>
      <div class="card-body">
        <% if @activities.any? %>
          <div class="activity-timeline">
            <% @activities.each do |activity| %>
              <div class="activity-item">
                <div class="activity-dot <%= activity.activity_type %>">
                  <%= case activity.activity_type
                      when "status_change" then raw("&#8594;")
                      when "note" then raw("&#9998;")
                      when "call" then raw("&#9742;")
                      when "assignment" then raw("&#8644;")
                      else raw("&#8226;")
                      end %>
                </div>
                <div class="activity-content">
                  <div class="activity-text"><%= activity.content %></div>
                  <div class="activity-meta">
                    <%= activity.user&.nickname || "시스템" %>
                    &middot;
                    <%= activity.created_at.strftime("%m/%d %H:%M") %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="info-text">아직 활동 기록이 없습니다</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
