<%= form_with model: [:admin, form], local: true do |f| %>
  <% if form.errors.any? %>
    <div class="form-errors">
      <% form.errors.full_messages.each do |msg| %>
        <p class="error-text"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <label class="form-label">폼 이름 *</label>
    <%= f.text_field :name, class: "form-input", required: true, placeholder: "예: 무료 상담 신청" %>
  </div>

  <% if form.persisted? %>
    <div class="form-group">
      <label class="form-label">공유 링크</label>
      <div class="link-copy-row">
        <code class="link-display" id="form-url"><%= request.base_url %>/f/<%= form.slug %></code>
        <button type="button" class="btn-secondary btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('form-url').textContent).then(()=>{this.textContent='복사됨!';setTimeout(()=>{this.textContent='복사'},1500)})">복사</button>
      </div>
    </div>
  <% end %>

  <div class="form-group">
    <label class="form-label">개인정보 동의 안내문 <span style="color: var(--text-tertiary); font-weight: 400;">(비워두면 미표시)</span></label>
    <%= f.text_area :privacy_policy_text, class: "form-textarea", rows: 2,
        placeholder: '예: 개인정보 수집 및 활용에 동의합니다.' %>
  </div>

  <div class="form-group">
    <label class="form-label">제출 버튼 텍스트</label>
    <%= f.text_field :submit_button_text, class: "form-input", placeholder: "상담문의" %>
  </div>

  <%# 숨김 필드 — 기본값 유지 %>
  <%= f.hidden_field :description, value: form.description %>
  <%= f.hidden_field :thank_you_message, value: form.thank_you_message.presence || "문의가 접수되었습니다. 빠르게 연락 드리겠습니다." %>
  <%= f.hidden_field :redirect_url, value: form.redirect_url %>

  <h3 class="section-title" style="margin-top: 24px;">문의 필드</h3>

  <div data-controller="form-builder">
    <div data-form-builder-target="container">
      <% form.form_fields.each_with_index do |field, index| %>
        <%= f.fields_for :form_fields, field, index: index do |ff| %>
          <div class="fb-simple-row" data-form-builder-target="field">
            <div class="fb-simple-grip">&#x2630;</div>
            <div class="fb-simple-label">
              <%= ff.text_field :label, class: "fb-input", placeholder: "질문 입력", required: true %>
            </div>
            <div class="fb-simple-type">
              <%= ff.select :field_type,
                  [["텍스트", "text"], ["이메일", "email"], ["전화번호", "phone"],
                   ["드롭다운", "select"], ["서술형", "textarea"], ["버튼선택", "button_select"]],
                  {}, { class: "fb-select" } %>
            </div>
            <div class="fb-simple-options">
              <%= ff.text_field :options, class: "fb-input", placeholder: "선택지 (쉼표 구분)" %>
            </div>
            <label class="fb-simple-check">
              <%= ff.check_box :required %> 필수
            </label>
            <button type="button" class="btn-remove-sm" data-action="click->form-builder#removeField">&times;</button>
            <%# 자동 생성 필드 %>
            <%= ff.hidden_field :name, value: field.name.presence || "field_#{index}" %>
            <%= ff.hidden_field :position, value: index %>
            <%= ff.hidden_field :placeholder, value: field.placeholder %>
            <%= ff.hidden_field :subtitle, value: field.subtitle %>
            <%= ff.hidden_field :half_width, value: field.half_width ? "1" : "0" %>
          </div>
        <% end %>
      <% end %>
    </div>

    <button type="button" class="btn-add-field"
            data-action="click->form-builder#addField"
            data-form-builder-target="addBtn">
      + 필드 추가
    </button>
  </div>

  <div class="form-actions">
    <%= f.submit form.persisted? ? "저장" : "폼 생성", class: "btn-primary" %>
    <%= link_to "취소", admin_forms_path, class: "btn-secondary" %>
  </div>
<% end %>
