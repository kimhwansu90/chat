<% content_for(:title, "문의 폼 - HS Solution") %>
<div class="page-header">
  <div>
    <h1 class="page-title">문의 폼</h1>
    <p class="page-subtitle">폼 생성 → 링크 공유 → 리드 자동 수집</p>
  </div>
  <%= link_to "+ 새 폼 만들기", new_admin_form_path, class: "btn-primary btn-sm" %>
</div>

<% if @forms.any? %>
  <div class="form-cards-grid">
    <% @forms.each do |form| %>
      <div class="form-card">
        <div class="form-card-header">
          <h3 class="form-card-name"><%= link_to form.name, admin_form_path(form) %></h3>
          <% if form.active? %>
            <span class="badge badge-active">활성</span>
          <% else %>
            <span class="badge badge-inactive">비활성</span>
          <% end %>
        </div>

        <div class="form-card-link">
          <code id="form-url-<%= form.id %>"><%= request.base_url %>/f/<%= form.slug %></code>
          <button type="button" class="btn-copy-sm"
                  onclick="navigator.clipboard.writeText(document.getElementById('form-url-<%= form.id %>').textContent).then(()=>{this.textContent='복사됨!';setTimeout(()=>{this.textContent='복사'},1500)})">복사</button>
        </div>

        <div class="form-card-stats">
          <div class="form-card-stat">
            <span class="form-card-stat-value"><%= form.leads.count %></span>
            <span class="form-card-stat-label">리드</span>
          </div>
          <div class="form-card-stat">
            <span class="form-card-stat-value"><%= form.form_fields.count %></span>
            <span class="form-card-stat-label">필드</span>
          </div>
        </div>

        <div class="form-card-actions">
          <%= link_to "미리보기", public_form_path(form_slug: form.slug), class: "btn-secondary btn-sm", target: "_blank" %>
          <%= link_to "수정", edit_admin_form_path(form), class: "btn-secondary btn-sm" %>
          <%= button_to form.active? ? "비활성화" : "활성화",
              toggle_active_admin_form_path(form),
              method: :patch,
              class: form.active? ? "btn-warning btn-sm" : "btn-success btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <p class="empty-state-text">아직 생성된 폼이 없습니다</p>
    <%= link_to "첫 폼 만들기", new_admin_form_path, class: "btn-primary btn-sm" %>
  </div>
<% end %>
