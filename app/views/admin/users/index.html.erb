<% content_for(:title, "팀 관리 - HS Solution") %>
<div class="page-header">
  <div>
    <h1 class="page-title">팀 관리</h1>
    <p class="page-subtitle">팀원 계정 관리</p>
  </div>
  <%= link_to "팀원 추가", new_admin_user_path, class: "btn-primary btn-sm" %>
</div>

<div class="table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th>아이디</th>
        <th>닉네임</th>
        <th>역할</th>
        <th>이메일</th>
        <th>상태</th>
        <th>마지막 접속</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.username %></td>
          <td><strong><%= user.nickname %></strong></td>
          <td><span class="badge badge-<%= user.role %>"><%= user.role %></span></td>
          <td><%= user.email || "-" %></td>
          <td>
            <% if user.active? %>
              <span class="badge badge-active">활성</span>
            <% else %>
              <span class="badge badge-inactive">비활성</span>
            <% end %>
          </td>
          <td><%= user.last_seen_at&.strftime("%m/%d %H:%M") || "-" %></td>
          <td>
            <%= link_to "수정", edit_admin_user_path(user), class: "btn-secondary btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
