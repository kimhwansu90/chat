<% content_for(:title, "팀원 추가 - HS Solution") %>
<div class="admin-form-page">
  <div class="page-header">
    <h1 class="page-title">팀원 추가</h1>
    <%= link_to "목록", admin_users_path, class: "btn-secondary btn-sm" %>
  </div>

  <div class="admin-form-card">
    <%= form_with model: [:admin, @user], url: admin_users_path, method: :post do |f| %>
      <% if @user.errors.any? %>
        <div class="form-errors">
          <% @user.errors.full_messages.each do |msg| %>
            <p class="error-text"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-group">
        <label class="form-label">아이디 *</label>
        <%= f.text_field :username, class: "form-input", required: true, placeholder: "영문/숫자", autocomplete: "off" %>
      </div>
      <div class="form-group">
        <label class="form-label">닉네임 *</label>
        <%= f.text_field :nickname, class: "form-input", required: true, placeholder: "표시 이름" %>
      </div>
      <div class="form-group">
        <label class="form-label">이메일</label>
        <%= f.email_field :email, class: "form-input", placeholder: "이메일" %>
      </div>
      <div class="form-group">
        <label class="form-label">전화번호</label>
        <%= f.text_field :phone, class: "form-input", placeholder: "010-1234-5678" %>
      </div>
      <div class="form-group">
        <label class="form-label">역할</label>
        <% selectable_roles = User::ROLES.reject { |r| %w[admin sales_rep].include?(r) } %>
        <%= f.select :role,
            selectable_roles.map { |r| [User::ROLE_LABELS[r] || r, r] },
            { selected: "team1" },
            class: "form-select" %>
      </div>
      <div class="form-group">
        <label class="form-label">비밀번호 *</label>
        <%= f.password_field :password, class: "form-input", required: true, autocomplete: "new-password" %>
      </div>
      <div class="form-group">
        <label class="form-label">비밀번호 확인 *</label>
        <%= f.password_field :password_confirmation, class: "form-input", required: true, autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "생성", class: "btn-primary" %>
        <%= link_to "취소", admin_users_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
