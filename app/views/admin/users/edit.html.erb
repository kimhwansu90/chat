<% content_for(:title, "팀원 수정 - HS Solution") %>
<div class="admin-form-page">
  <div class="page-header">
    <h1 class="page-title">팀원 수정 - <%= @user.nickname %></h1>
    <%= link_to "목록", admin_users_path, class: "btn-secondary btn-sm" %>
  </div>

  <div class="admin-form-card">
    <%= form_with model: [:admin, @user], url: admin_user_path(@user), method: :patch do |f| %>
      <% if @user.errors.any? %>
        <div class="form-errors">
          <% @user.errors.full_messages.each do |msg| %>
            <p class="error-text"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-group">
        <label class="form-label">아이디</label>
        <%= f.text_field :username, class: "form-input", disabled: true %>
      </div>
      <div class="form-group">
        <label class="form-label">닉네임 *</label>
        <%= f.text_field :nickname, class: "form-input", required: true %>
      </div>
      <div class="form-group">
        <label class="form-label">이메일</label>
        <%= f.email_field :email, class: "form-input" %>
      </div>
      <div class="form-group">
        <label class="form-label">전화번호</label>
        <%= f.text_field :phone, class: "form-input" %>
      </div>
      <div class="form-group">
        <label class="form-label">역할</label>
        <%= f.select :role, User::ROLES.map { |r| [r, r] }, {}, class: "form-select" %>
      </div>
      <div class="form-group">
        <label class="form-checkbox">
          <%= f.check_box :active %> 활성 계정
        </label>
      </div>
      <div class="form-group">
        <label class="form-label">새 비밀번호 (변경 시에만)</label>
        <%= f.password_field :password, class: "form-input", autocomplete: "new-password" %>
      </div>
      <div class="form-group">
        <label class="form-label">비밀번호 확인</label>
        <%= f.password_field :password_confirmation, class: "form-input", autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "수정", class: "btn-primary" %>
        <%= link_to "취소", admin_users_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
