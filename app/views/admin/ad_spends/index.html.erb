<% content_for(:title, "광고비 관리 - HS Solution") %>

<div class="page-header">
  <div>
    <h1 class="page-title">광고비 관리</h1>
    <p class="page-subtitle">채널별 광고비를 수동으로 입력하고 ROI를 계산합니다</p>
  </div>
  <%= link_to "+ 광고비 추가", new_admin_ad_spend_path, class: "btn-primary" %>
</div>

<%# 채널별 합계 %>
<% if @total_by_channel.any? %>
  <div class="kpi-grid" style="margin-bottom: 24px;">
    <% @total_by_channel.each do |channel, total| %>
      <div class="kpi-card">
        <div class="kpi-label"><%= channel.upcase %> 총 광고비</div>
        <div class="kpi-value" style="font-size: 20px;"><%= number_with_delimiter(total) %>원</div>
      </div>
    <% end %>
    <div class="kpi-card" style="border-top: 3px solid var(--primary);">
      <div class="kpi-label">전체 합계</div>
      <div class="kpi-value" style="font-size: 20px; color: var(--primary);">
        <%= number_with_delimiter(@total_by_channel.values.sum) %>원
      </div>
    </div>
  </div>
<% end %>

<div class="table-wrapper">
  <% if @ad_spends.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>채널</th>
          <th>캠페인명</th>
          <th>기간</th>
          <th style="text-align: right;">광고비</th>
          <th>메모</th>
          <th>등록자</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @ad_spends.each do |ad| %>
          <tr>
            <td>
              <span class="badge" style="background: #e0e7ff; color: #3730a3;"><%= ad.channel.upcase %></span>
            </td>
            <td style="font-weight: 500;"><%= ad.campaign_name %></td>
            <td style="font-size: 13px; color: var(--text-secondary);">
              <%= ad.period_start.strftime("%Y.%m.%d") %> ~ <%= ad.period_end.strftime("%Y.%m.%d") %>
            </td>
            <td style="text-align: right; font-weight: 700; color: var(--danger);">
              <%= number_with_delimiter(ad.amount) %>원
            </td>
            <td style="font-size: 13px; color: var(--text-secondary);"><%= ad.memo || "-" %></td>
            <td style="font-size: 13px;"><%= ad.created_by&.nickname || "-" %></td>
            <td>
              <div class="btn-group">
                <%= link_to "수정", edit_admin_ad_spend_path(ad), class: "btn-secondary btn-sm" %>
                <%= button_to "삭제", admin_ad_spend_path(ad), method: :delete,
                    class: "btn-danger",
                    data: { confirm: "삭제하시겠습니까?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p class="empty-state-text">등록된 광고비가 없습니다</p>
      <%= link_to "+ 광고비 추가", new_admin_ad_spend_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
