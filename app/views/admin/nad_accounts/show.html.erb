<% content_for(:title, "#{@nad_account.name} - LeadHub") %>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= @nad_account.name %></h1>
    <p class="page-subtitle">Customer ID: <%= @nad_account.customer_id %></p>
  </div>
  <div class="page-actions">
    <%= button_to "지금 동기화", sync_admin_nad_account_path(@nad_account), method: :post, class: "btn btn-primary" %>
    <%= link_to "수정", edit_admin_nad_account_path(@nad_account), class: "btn btn-secondary" %>
    <%= link_to "← 목록", admin_nad_accounts_path, class: "btn btn-secondary" %>
  </div>
</div>

<% if notice %><div class="alert alert-success"><%= notice %></div><% end %>
<% if alert %><div class="alert alert-danger"><%= alert %></div><% end %>

<div class="stats-grid">
  <div class="kpi-card">
    <div class="kpi-label">캠페인</div>
    <div class="kpi-value"><%= @campaigns.count %></div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">총 광고그룹</div>
    <div class="kpi-value"><%= NadAdGroup.joins(nad_campaign: :nad_account).where(nad_accounts: { id: @nad_account.id }).count %></div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">마지막 동기화</div>
    <div class="kpi-value" style="font-size: 1rem;">
      <%= @nad_account.last_synced_at&.strftime("%m/%d %H:%M") || "-" %>
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">계정 상태</div>
    <div class="kpi-value" style="font-size: 1rem;">
      <%= @nad_account.active? ? "활성" : "비활성" %>
    </div>
  </div>
</div>

<div class="card" style="margin-top: 1.5rem;">
  <div class="card-header">
    <h3>캠페인 목록</h3>
  </div>
  <% if @campaigns.empty? %>
    <div class="empty-state">
      <p>동기화된 캠페인이 없습니다. 동기화 버튼을 눌러 캠페인을 가져오세요.</p>
    </div>
  <% else %>
    <table class="data-table">
      <thead>
        <tr>
          <th>캠페인명</th>
          <th>유형</th>
          <th>상태</th>
          <th>일예산</th>
          <th>광고그룹</th>
        </tr>
      </thead>
      <tbody>
        <% @campaigns.each do |campaign| %>
          <tr>
            <td><%= link_to campaign.name, admin_nad_campaign_path(campaign) %></td>
            <td><code><%= campaign.campaign_type %></code></td>
            <td><span class="badge <%= campaign.status == 'ELIGIBLE' ? 'badge-success' : 'badge-secondary' %>"><%= campaign.status_label %></span></td>
            <td><%= campaign.budget ? "#{campaign.budget.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1,').reverse}원" : "-" %></td>
            <td><%= campaign.nad_ad_groups.count %>개</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
