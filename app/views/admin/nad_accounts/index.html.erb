<% content_for(:title, "광고 계정 관리 - HS Solution") %>

<div class="page-header">
  <div>
    <h1 class="page-title">광고 계정 관리</h1>
    <p class="page-subtitle">네이버 검색광고 계정을 등록하고 관리합니다</p>
  </div>
  <%= link_to "계정 추가", new_admin_nad_account_path, class: "btn btn-primary" %>
</div>

<% if notice %>
  <div class="alert alert-success"><%= notice %></div>
<% end %>
<% if alert %>
  <div class="alert alert-danger"><%= alert %></div>
<% end %>

<% if @nad_accounts.empty? %>
  <div class="card">
    <div class="empty-state">
      <div style="font-size: 3rem; margin-bottom: 1rem;">📡</div>
      <h3>등록된 광고 계정이 없습니다</h3>
      <p>네이버 검색광고 계정을 등록하면 캠페인과 성과 데이터를 자동으로 동기화할 수 있습니다.</p>
      <%= link_to "첫 계정 등록", new_admin_nad_account_path, class: "btn btn-primary" %>
    </div>
  </div>
<% else %>
  <div class="card">
    <table class="data-table">
      <thead>
        <tr>
          <th>계정명</th>
          <th>Customer ID</th>
          <th>캠페인 수</th>
          <th>마지막 동기화</th>
          <th>상태</th>
          <th>작업</th>
        </tr>
      </thead>
      <tbody>
        <% @nad_accounts.each do |account| %>
          <tr>
            <td><strong><%= link_to account.name, admin_nad_account_path(account) %></strong></td>
            <td><code><%= account.customer_id %></code></td>
            <td><%= account.nad_campaigns.count %>개</td>
            <td>
              <% if account.last_synced_at %>
                <%= account.last_synced_at.strftime("%Y.%m.%d %H:%M") %>
              <% else %>
                <span class="text-muted">미동기화</span>
              <% end %>
            </td>
            <td>
              <span class="badge <%= account.active? ? 'badge-success' : 'badge-secondary' %>">
                <%= account.active? ? "활성" : "비활성" %>
              </span>
            </td>
            <td class="table-actions">
              <%= button_to "동기화", sync_admin_nad_account_path(account), method: :post, class: "btn btn-sm btn-secondary" %>
              <%= link_to "수정", edit_admin_nad_account_path(account), class: "btn btn-sm btn-secondary" %>
              <%= button_to "삭제", admin_nad_account_path(account), method: :delete,
                  form: { data: { turbo_confirm: "정말 삭제하시겠습니까?" } },
                  class: "btn btn-sm btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
