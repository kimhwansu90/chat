<% content_for(:title, "광고 성과 리포트 - HS Solution") %>

<div class="page-header">
  <div>
    <h1 class="page-title">광고 성과 리포트</h1>
    <p class="page-subtitle">채널별 지출/매출 및 팀별 계약 결과</p>
  </div>
  <div style="display: flex; gap: 8px;">
    <%= link_to "+ 광고비 입력", new_admin_ad_spend_path, class: "btn-secondary btn-sm" %>
    <%= link_to "← 리포트", admin_reports_path, class: "btn-secondary btn-sm" %>
  </div>
</div>

<%# 날짜 필터 %>
<div class="card" style="margin-bottom: 24px;">
  <%= form_with url: roi_report_admin_reports_path, method: :get, local: true,
      style: "display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; padding: 16px;" do |f| %>
    <div>
      <label class="form-label" style="margin-bottom: 4px;">시작일</label>
      <input type="date" name="date_from" value="<%= @date_from %>" class="form-input" style="width: 160px;">
    </div>
    <div>
      <label class="form-label" style="margin-bottom: 4px;">종료일</label>
      <input type="date" name="date_to" value="<%= @date_to %>" class="form-input" style="width: 160px;">
    </div>
    <button type="submit" class="btn-primary">조회</button>
  <% end %>
</div>

<%# 전체 KPI %>
<div class="kpi-grid" style="margin-bottom: 24px;">
  <div class="kpi-card" style="border-top: 3px solid var(--danger);">
    <div class="kpi-label">총 광고비 지출</div>
    <div class="kpi-value" style="font-size: 22px; color: var(--danger);">
      <%= number_with_delimiter(@total_ad_spend) %>원
    </div>
  </div>
  <div class="kpi-card" style="border-top: 3px solid var(--success);">
    <div class="kpi-label">총 매출 (계약금액 합산)</div>
    <div class="kpi-value" style="font-size: 22px; color: var(--success);">
      <%= number_with_delimiter(@total_revenue) %>원
    </div>
  </div>
  <div class="kpi-card" style="border-top: 3px solid <%= @net_profit >= 0 ? 'var(--success)' : 'var(--danger)' %>;">
    <div class="kpi-label">순이익</div>
    <div class="kpi-value" style="font-size: 22px; color: <%= @net_profit >= 0 ? 'var(--success)' : 'var(--danger)' %>;">
      <%= @net_profit >= 0 ? "+" : "" %><%= number_with_delimiter(@net_profit) %>원
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">ROI</div>
    <div class="kpi-value" style="font-size: 22px; color: <%= @roi_percent >= 0 ? 'var(--success)' : 'var(--danger)' %>;">
      <%= @roi_percent >= 0 ? "+" : "" %><%= @roi_percent %>%
    </div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">계약 건수</div>
    <div class="kpi-value" style="font-size: 22px;"><%= @total_converted %>건</div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">

  <%# 채널별 광고비 지출 %>
  <div class="card">
    <div class="card-header">📣 채널별 광고비 지출</div>
    <div class="card-body" style="padding: 0;">
      <% if @channel_stats.any? %>
        <table class="data-table">
          <thead>
            <tr>
              <th>채널</th>
              <th style="text-align: right;">광고비 지출</th>
              <th style="text-align: right;">비율</th>
            </tr>
          </thead>
          <tbody>
            <% @channel_stats.each do |s| %>
              <tr>
                <td>
                  <span class="badge" style="background: #e0e7ff; color: #3730a3;">
                    <%= s[:channel].upcase %>
                  </span>
                </td>
                <td style="text-align: right; color: var(--danger); font-weight: 600;">
                  <%= number_with_delimiter(s[:spend]) %>원
                </td>
                <td style="text-align: right; font-size: 13px; color: var(--text-secondary);">
                  <%= @total_ad_spend > 0 ? "#{(s[:spend].to_f / @total_ad_spend * 100).round(1)}%" : "-" %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr style="background: var(--bg-secondary);">
              <td style="font-weight: 700; padding: 10px 16px;">합계</td>
              <td style="text-align: right; font-weight: 700; color: var(--danger); padding: 10px 16px;">
                <%= number_with_delimiter(@total_ad_spend) %>원
              </td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <div class="empty-state">
          <p class="empty-state-text">이 기간에 등록된 광고비가 없습니다</p>
          <%= link_to "+ 광고비 입력", new_admin_ad_spend_path, class: "btn-primary btn-sm" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# 팀별 계약 결과 %>
  <div class="card">
    <div class="card-header">👥 팀별 계약 결과</div>
    <div class="card-body" style="padding: 0;">
      <% if @team_stats.any? %>
        <table class="data-table">
          <thead>
            <tr>
              <th>담당자</th>
              <th>역할</th>
              <th style="text-align: right;">계약수</th>
              <th style="text-align: right;">매출</th>
            </tr>
          </thead>
          <tbody>
            <% @team_stats.each do |s| %>
              <tr>
                <td style="font-weight: 600;">
                  <%= s[:rep]&.nickname || "미배정" %>
                </td>
                <td>
                  <% role = s[:rep]&.role %>
                  <span class="badge badge-<%= role %>">
                    <%= User::ROLE_LABELS[role] || role || "-" %>
                  </span>
                </td>
                <td style="text-align: right;"><%= s[:count] %>건</td>
                <td style="text-align: right; font-weight: 700; color: var(--success);">
                  <%= number_with_delimiter(s[:revenue]) %>원
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr style="background: var(--bg-secondary);">
              <td colspan="2" style="font-weight: 700; padding: 10px 16px;">합계</td>
              <td style="text-align: right; font-weight: 700; padding: 10px 16px;">
                <%= @total_converted %>건
              </td>
              <td style="text-align: right; font-weight: 700; color: var(--success); padding: 10px 16px;">
                <%= number_with_delimiter(@team_stats.sum { |s| s[:revenue] }) %>원
              </td>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <div class="empty-state">
          <p class="empty-state-text">이 기간에 계약 완료 건이 없습니다</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# 최근 계약 리드 %>
<div class="card" style="margin-bottom: 24px;">
  <div class="card-header">✅ 계약 완료 리드</div>
  <% if @recent_contracts.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>이름</th>
          <th>전화번호</th>
          <th>채널</th>
          <th>담당자</th>
          <th style="text-align: right;">계약금액</th>
          <th>계약일</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_contracts.each do |lead| %>
          <tr>
            <td>
              <%= link_to lead.name, admin_lead_path(lead),
                  style: "color: var(--primary); text-decoration: none; font-weight: 500;" %>
            </td>
            <td><%= lead.phone || "-" %></td>
            <td><%= lead.utm_source || "직접" %></td>
            <td><%= lead.assigned_to&.nickname || "미배정" %></td>
            <td style="text-align: right; font-weight: 700; color: var(--success);">
              <%= number_with_delimiter(lead.contract_value.to_i) %>원
            </td>
            <td><%= lead.contracted_at&.strftime("%Y-%m-%d") || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p class="empty-state-text">해당 기간에 계약 완료 리드가 없습니다</p>
    </div>
  <% end %>
</div>

<%# 광고비 상세 내역 %>
<div class="card">
  <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
    <span>📋 광고비 상세 내역</span>
    <%= link_to "+ 광고비 추가", new_admin_ad_spend_path, class: "btn-primary btn-sm" %>
  </div>
  <% if @ad_spends.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>채널</th>
          <th>캠페인명</th>
          <th>기간</th>
          <th style="text-align: right;">지출</th>
          <th style="text-align: right;">매출</th>
          <th>메모</th>
        </tr>
      </thead>
      <tbody>
        <% @ad_spends.each do |ad| %>
          <tr>
            <td><span class="badge" style="background: #e0e7ff; color: #3730a3;"><%= ad.channel.upcase %></span></td>
            <td><%= ad.campaign_name %></td>
            <td style="font-size: 13px; color: var(--text-secondary);">
              <%= ad.period_start.strftime("%m/%d") %> ~ <%= ad.period_end.strftime("%m/%d") %>
            </td>
            <td style="text-align: right; color: var(--danger); font-weight: 600;">
              <%= number_with_delimiter(ad.amount) %>원
            </td>
            <td style="text-align: right; color: var(--success); font-weight: 600;">
              <%= ad.revenue > 0 ? "#{number_with_delimiter(ad.revenue)}원" : "-" %>
            </td>
            <td style="font-size: 13px; color: var(--text-secondary);"><%= ad.memo || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p class="empty-state-text">이 기간에 등록된 광고비가 없습니다</p>
      <%= link_to "+ 광고비 추가", new_admin_ad_spend_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
