<% content_for(:title, @form.name) %>

<div class="pf-page">
  <div class="pf-container">
    <div class="pf-header">
      <h1 class="pf-title"><%= @form.name %></h1>
      <% if @form.description.present? %>
        <p class="pf-desc"><%= @form.description %></p>
      <% end %>
    </div>

    <%= form_with url: public_form_submit_path(form_slug: @form.slug), method: :post, local: true do |f| %>
      <%= hidden_field_tag :utm_source, params[:utm_source] %>
      <%= hidden_field_tag :utm_medium, params[:utm_medium] %>
      <%= hidden_field_tag :utm_campaign, params[:utm_campaign] %>
      <%= hidden_field_tag :utm_content, params[:utm_content] %>
      <%= hidden_field_tag :utm_term, params[:utm_term] %>

      <div class="pf-card">
        <% fields_to_render = @form_fields.reject { |f| f.field_type == "privacy_checkbox" } %>
        <% i = 0 %>
        <div class="pf-fields">
          <% while i < fields_to_render.length %>
            <% field = fields_to_render[i] %>
            <% next_field = fields_to_render[i + 1] %>

            <% if field.half_width && next_field&.half_width? %>
              <div class="pf-row-two">
                <%= render "field", field: field %>
                <%= render "field", field: next_field %>
              </div>
              <% i += 2 %>
            <% else %>
              <div class="pf-row-one">
                <%= render "field", field: field %>
              </div>
              <% i += 1 %>
            <% end %>
          <% end %>
        </div>
      </div>

      <% if @form.privacy_policy_text.present? %>
        <div class="pf-privacy-section">
          <div class="pf-privacy-toggle">
            <span class="pf-privacy-title">개인정보 수집 및 이용 동의</span>
            <button type="button" class="pf-privacy-expand" onclick="this.closest('.pf-privacy-section').classList.toggle('open')">전문 보기</button>
          </div>
          <div class="pf-privacy-content">
            <p class="pf-privacy-text"><%= simple_format(@form.privacy_policy_text) %></p>
          </div>
          <label class="pf-checkbox-label">
            <input type="checkbox" name="privacy_agree" required>
            <span>위 개인정보 수집 및 이용에 동의합니다. <span class="pf-required">*</span></span>
          </label>
        </div>
      <% end %>

      <div class="pf-submit">
        <button type="submit" class="pf-btn-submit">
          <%= @form.submit_button_text.presence || "상담 문의하기" %>
        </button>
      </div>

    <% end %>
  </div>
</div>
