<% content_for(:title, @form.name) %>
<div class="public-form-container">
  <div class="public-form-card">
    <h1 class="public-form-title"><%= @form.name %></h1>
    <% if @form.description.present? %>
      <p class="public-form-description"><%= @form.description %></p>
    <% end %>

    <%= form_with url: public_form_submit_path(form_slug: @form.slug), method: :post, local: true do |f| %>
      <%# UTM 파라미터를 hidden field로 전달 %>
      <%= hidden_field_tag :utm_source, params[:utm_source] %>
      <%= hidden_field_tag :utm_medium, params[:utm_medium] %>
      <%= hidden_field_tag :utm_campaign, params[:utm_campaign] %>
      <%= hidden_field_tag :utm_content, params[:utm_content] %>
      <%= hidden_field_tag :utm_term, params[:utm_term] %>

      <% @form_fields.each do |field| %>
        <div class="form-group">
          <label class="form-label"><%= field.label %><%= " *" if field.required? %></label>
          <% case field.field_type %>
          <% when "text" %>
            <input type="text" name="lead[<%= field.name %>]" class="form-input"
                   placeholder="<%= field.label %>" <%= "required" if field.required? %>>
          <% when "email" %>
            <input type="email" name="lead[<%= field.name %>]" class="form-input"
                   placeholder="이메일 주소" <%= "required" if field.required? %>>
          <% when "phone" %>
            <input type="tel" name="lead[<%= field.name %>]" class="form-input"
                   placeholder="연락처" <%= "required" if field.required? %>>
          <% when "textarea" %>
            <textarea name="lead[<%= field.name %>]" class="form-textarea"
                      placeholder="<%= field.label %>" rows="4" <%= "required" if field.required? %>></textarea>
          <% when "select" %>
            <select name="lead[<%= field.name %>]" class="form-select" <%= "required" if field.required? %>>
              <option value="">선택하세요</option>
              <% if field.options.present? %>
                <% field.options.split(",").each do |opt| %>
                  <option value="<%= opt.strip %>"><%= opt.strip %></option>
                <% end %>
              <% end %>
            </select>
          <% end %>
        </div>
      <% end %>

      <div class="form-actions">
        <%= f.submit "문의하기", class: "btn-primary btn-full" %>
      </div>
    <% end %>
  </div>
</div>
